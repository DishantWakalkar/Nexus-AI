# Copy this file to .env and fill in real values. Never commit .env.

APP_ENV=development

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Security
# Generate SECRET_KEY:      python -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION_SALT: python -c "import secrets; print(secrets.token_hex(16))"
SECRET_KEY=your-secret-key-at-least-32-hex-chars
ENCRYPTION_SALT=your-encryption-salt-16-hex-chars

# OAuth - Notion (api.notion.com/v1/oauth -> Integration settings)
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# OAuth - Slack (api.slack.com/apps -> OAuth & Permissions)
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# OAuth - Google Drive (console.cloud.google.com -> Credentials)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_API_KEY=your-google-api-key-for-picker

# URLs - update both for production
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# AI providers
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key

# HuggingFace
HF_HUB_TIMEOUT=120
